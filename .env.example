# Sunucu tarafı (Pi veya lokal dev)
# HUB_HOST: lokalde 127.0.0.1; Pi'de Tailscale IP'si (100.x.x.x)
# HUB_TOKEN: boşsa auth kapalı (sadece lokal dev)
# GEMINI_API_KEY: boşsa vektör arama kapalı, FTS-only çalışır
HUB_DB_PATH=./data/hub.db
HUB_DEPLOYMENT_PROFILE=personal
HUB_HOST=127.0.0.1
HUB_PORT=8033
HUB_TOKEN=
HUB_ALLOW_LEGACY_ADMIN=true
# Team/enterprise: HUB_TOKEN boş bırak; scoped token policies kullan.
# HUB_AUTH_TOKENS=[{"id":"agent-reader","token":"replace-with-32-plus-random-chars","scopes":["context:read","knowledge:read","project:read","session:read"],"projects":["*"]}]
# HUB_ALLOW_QUERY_TOKEN=false
# HUB_STRICT_PROJECTS=true
# HUB_ACCEPT_LEGACY_VECTORS=false
# HUB_RATE_LIMIT_PER_MINUTE=600
HUB_VECTOR_BACKEND=sqlite-vec
# Optional scale-out search projection. SQLite remains the source of truth.
# HUB_VECTOR_BACKEND=qdrant
# HUB_QDRANT_URL=https://qdrant.internal.example
# HUB_QDRANT_API_KEY=<secret>
# HUB_QDRANT_COLLECTION_PREFIX=mnema
# HUB_QDRANT_TIMEOUT_MS=3000
# HUB_QDRANT_BATCH_SIZE=128
# HUB_QDRANT_FLUSH_INTERVAL_MS=2000
GEMINI_API_KEY=
EMBEDDING_DIM=768

# Local-first eşitleme (PC'lerde doldur; Pi'de boş bırak — Pi primary'dir)
# Virgülle ayrılmış çoklu adres desteklenir (Tailscale ölürse LAN'a düşer):
# HUB_PRIMARY_URL=http://100.110.9.26:8033,http://192.168.1.53:8033
# HUB_PRIMARY_TOKEN=<pi'deki HUB_TOKEN>
# HUB_SYNC_INTERVAL=60

# Recall skorlamasında güncellik decay yarı ömrü (gün). Büyütmek eski kayıtları
# daha uzun canlı tutar; küçültmek yeni kayıtları daha agresif önceliklendirir.
# HUB_DECAY_HALFLIFE_DAYS=90
