{
  "name": "mnema",
  "version": "0.1.0",
  "description": "Local-first shared memory, RAG, project maps and context for AI agents over MCP + REST",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "hub": "./dist/cli/index.js",
    "hub-server": "./dist/server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "backup:copy": "tsx scripts/backup-copy.ts",
    "benchmark:vector": "tsx scripts/vector-benchmark.ts",
    "benchmark:vector:smoke": "tsx scripts/vector-benchmark.ts --rows=2000 --queries=30 --projects=10 --dim=128 --gate",
    "dev": "tsx src/server/index.ts",
    "eval:context": "tsx scripts/context-eval.ts",
    "eval:context:release": "tsx scripts/context-eval.ts --release",
    "migration:audit": "tsx scripts/migration-audit.ts",
    "reset:knowledge": "tsx scripts/reset-knowledge.ts",
    "smoke:security": "tsx scripts/security-smoke.ts",
    "smoke:saas-security": "tsx scripts/saas-security-smoke.ts",
    "smoke:tenant": "tsx scripts/tenant-isolation-smoke.ts",
    "smoke:cloud-router": "tsx scripts/cloud-router-smoke.ts",
    "smoke:cloud": "npm run smoke:saas-security && npm run smoke:tenant && npm run smoke:cloud-router",
    "smoke:generation": "tsx scripts/generation-smoke.ts",
    "smoke:qdrant": "tsx scripts/qdrant-smoke.ts",
    "smoke": "tsx scripts/smoke.ts",
    "hub": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.2.0",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "sqlite-vec": "^0.1.6",
    "unpdf": "^1.6.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
