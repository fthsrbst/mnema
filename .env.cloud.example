# Public browser configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLIC_KEY
# VITE_SUPABASE_ANON_KEY=YOUR_LEGACY_PUBLIC_ANON_KEY
VITE_PADDLE_CLIENT_TOKEN=test_YOUR_CLIENT_TOKEN
VITE_PADDLE_ENVIRONMENT=sandbox

# Server-only configuration. Never expose these with a VITE_ prefix.
CLOUD_APP_URL=https://app.example.com
CLOUD_HTTPS_ONLY=false
# Set only when exactly this many trusted reverse proxies are in front of Node.
CLOUD_TRUST_PROXY_HOPS=0
CLOUD_RATE_LIMIT_PER_MINUTE=300
CLOUD_WEBHOOK_RATE_LIMIT_PER_MINUTE=120
# Required in production; a single shared Valkey/Redis backs every Node replica.
CLOUD_RATE_LIMIT_REDIS_URL=redis://:CHANGE_ME@valkey:6379
# Hosted Cloud serves only Cloud APIs by default. Enabling Community APIs also
# requires separate scoped HUB_AUTH_TOKENS; never expose local-dev authority.
CLOUD_ENABLE_COMMUNITY_API=false
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLIC_KEY
# SUPABASE_ANON_KEY=YOUR_LEGACY_PUBLIC_ANON_KEY
# New Supabase projects should prefer a server-only sb_secret_ key. Legacy
# service-role keys remain supported during migration; configure only one.
SUPABASE_SECRET_KEY=sb_secret_YOUR_SERVER_ONLY_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_LEGACY_SERVER_ONLY_SERVICE_ROLE_KEY
PADDLE_API_KEY=pdl_sdbx_apikey_YOUR_SERVER_ONLY_KEY
PADDLE_WEBHOOK_SECRET=pdl_ntfset_YOUR_SERVER_ONLY_SECRET
PADDLE_ENVIRONMENT=sandbox
PADDLE_APPROVED_CHECKOUT_URL=https://app.example.com/billing/complete

# Catalog ids are server-owned; clients choose plan + interval, never price ids.
PADDLE_PRICE_STARTER_MONTHLY=pri_...
PADDLE_PRICE_STARTER_ANNUAL=pri_...
PADDLE_PRICE_PRO_MONTHLY=pri_...
PADDLE_PRICE_PRO_ANNUAL=pri_...
PADDLE_PRICE_TEAM_MONTHLY=pri_...
PADDLE_PRICE_TEAM_ANNUAL=pri_...
